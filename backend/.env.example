# Copy this file to .env and update values for your machine.
# Never commit .env to Git.

# API port (default 5000)
PORT=5000

# Local MongoDB (default for class demos)
MONGODB_URI=mongodb://127.0.0.1:27017/fitness-wellness-tracker

# MongoDB Atlas example (replace user, password, and cluster):
# MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/fitness-wellness-tracker

# Required — use a long random string (32+ characters) for JWT signing
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# Token lifetime (optional)
JWT_EXPIRES_IN=7d

# Frontend URL for CORS (match your Vite dev server)
CLIENT_URL=http://localhost:5173
